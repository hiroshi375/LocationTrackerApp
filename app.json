{
    "expo": {
        "name": "LocationTrackerApp",
        "slug": "LocationTrackerApp",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "locationtrackerapp",
        "userInterfaceStyle": "automatic",
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "NSLocationWhenInUseUsageDescription": "現在地を記録するために位置情報を使用します。"
            },
            "config": {
                "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
            },
            "bundleIdentifier": "com.hiroshisato.locationtrackerapp"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "permissions": [
                "android.permission.ACCESS_FINE_LOCATION",
                "android.permission.ACCESS_COARSE_LOCATION",
                "android.permission.RECORD_AUDIO"
            ],
            "predictiveBackGestureEnabled": false,
            "package": "com.hiroshisato.locationtrackerapp",
            "config": {
                "googleMaps": {
                    "apiKey": "AIzaSyAc-wHT7TQubDTcGxOnmlJ527xLIR9a3nw"
                }
            }
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            [
                "expo-image-picker",
                {
                    "photosPermission": "プロフィールアイコンを選択するために写真へのアクセスを使用します。",
                    "colors": {
                        "cropToolbarColor": "#ffffff",
                        "cropToolbarIconColor": "#2f4f66",
                        "cropToolbarActionTextColor": "#2f4f66",
                        "cropBackButtonIconColor": "#2f4f66",
                        "cropBackgroundColor": "#ffffff"
                    },
                    "dark": {
                        "colors": {
                            "cropToolbarColor": "#ffffff",
                            "cropToolbarIconColor": "#2f4f66",
                            "cropToolbarActionTextColor": "#2f4f66",
                            "cropBackButtonIconColor": "#2f4f66",
                            "cropBackgroundColor": "#ffffff"
                        }
                    }
                }
            ],
            [
                "expo-splash-screen",
                {
                    "image": "./assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#ffffff",
                    "dark": {
                        "backgroundColor": "#000000"
                    }
                }
            ],
            "expo-asset"
        ],
        "extra": {
            "eas": {
                "projectId": "f2148044-38b4-4da0-bc10-82d3b87398b3"
            }
        }
    }
}
